{
  "name": "subject-knowledge-integration-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "build": "npm --prefix frontend run build",
    "test": "python3 -m pytest backend/tests",
    "benchmark": "python3 scripts/run_rag_benchmark.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

