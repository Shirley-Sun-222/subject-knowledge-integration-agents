UPLOAD_DIR=./data/uploads
INDEX_DIR=./data/indexes
GENERATED_DIR=./data/generated
FRONTEND_ORIGIN=http://localhost:5173
PDF_RENDERER=playwright
SESSION_WORKSPACE_TTL_SECONDS=86400
